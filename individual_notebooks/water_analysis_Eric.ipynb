# Import the necessary Python libraries for data analysis and visualization
import pandas as pd
import matplotlib.pyplot as plt

# Load the public water supplier service area dataset from the local data folder
# Ensure the file path matches the location of your CSV file in the project repository
df = pd.read_csv("../data/public_water_systems_-_public_water_supplier_service_areas.csv")

# Display a basic overview of the dataset to verify successful loading
print("Data loaded successfully!")
print(f"Total dataset rows: {df.shape[0]}, Total dataset columns: {df.shape[1]}")
print("\nDataset column names:")
print(df.columns.tolist())
# Show the first 5 rows of the dataset for quick inspection
df.head()

# Filter the dataset to only include water systems in Allegheny County (Pittsburgh's home county)
pgh_water = df[df['CNTY_NAME'] == 'Allegheny']
print(f"\nNumber of water systems in Allegheny County: {len(pgh_water)}")

# Core Mapping: Link water supply companies to their corresponding Pittsburgh neighborhoods
# This mapping covers all major water suppliers in the filtered Allegheny County dataset
neighborhood_mapping = {
    # Pittsburgh core urban neighborhoods
    'AMER WATER CO PITTSBURGH DIST': 'Downtown/Oakland',
    'PITTSBURGH W AND S AUTH': 'Pittsburgh City',
    # Eastern Pittsburgh neighborhoods
    'WILKINSBURG PENN JT WATER AUTH': 'Wilkinsburg',
    'EAST PITTSBURGH BORO WATER': 'East Pittsburgh',
    'FAWN FRAZER JT WATER AUTH': 'Fawn Township',
    # Western Pittsburgh neighborhoods
    'WEST VIEW MUNI AUTH': 'West View',
    'CORAOPOLIS WATER AND SEWER AUTHORITY': 'Coraopolis',
    'MOON TWP MUNI AUTH': 'Moon Township',
    # Northern/Southern Pittsburgh neighborhoods
    'OAKMONT BORO MUNI AUTH': 'Oakmont',
    'HAMPTON SHALER WATER AUTH': 'Hampton/Shaler',
    'PLUM BORO MUNI AUTH': 'Plum',
    'ROBINSON TWP MUNI AUTH': 'Robinson Township',
    'WESTERN ALLEGHENY CNTY MUNI AU': 'Western Allegheny County',
    'BRACKENRIDGE BORO WATER': 'Brackenridge',
    'SPRINGDALE BORO WATER DEPT': 'Springdale',
    'FINDLAY TWP MUNI AUTH': 'Findlay Township',
    'VA HEALTHCARE SYSTEM HEINZ': 'Oakland'
}

# Add a new 'NEIGHBORHOOD' column to the dataset by mapping water companies to neighborhoods
pgh_water['NEIGHBORHOOD'] = pgh_water['NAME'].map(neighborhood_mapping)

# Aggregate water service area data by neighborhood (key modification for project requirements)
# Sum the total service area for each neighborhood and sort in descending order
neighborhood_water = pgh_water.groupby('NEIGHBORHOOD')['SHAPEAREA'].sum().sort_values(ascending=False)

# Create a bar chart to visualize total water service area by Pittsburgh neighborhood
# Set figure size for clear readability
plt.figure(figsize=(14, 7))
# Generate bar chart with a clean skyblue color scheme
neighborhood_water.plot(kind='bar', color='skyblue')
# Add clear, descriptive titles and axis labels
plt.title('Total Water Service Area by Pittsburgh Neighborhood', fontsize=16)
plt.xlabel('Neighborhood', fontsize=14)
plt.ylabel('Total Service Area (square units)', fontsize=14)
# Rotate x-axis labels to avoid overlap and set font size
plt.xticks(rotation=45, ha='right', fontsize=12)
# Adjust layout to fit all chart elements
plt.tight_layout()
# Disable scientific notation on the y-axis for easier number interpretation
plt.ticklabel_format(style='plain', axis='y')

# Save the visualization to the project's images folder with high resolution (300 DPI)
# bbox_inches='tight' ensures no chart elements are cut off in the saved image
plt.savefig("../images/water_by_neighborhood.png", dpi=300, bbox_inches='tight')
# Display the chart in the Jupyter Notebook
plt.show()

# Display the top 5 neighborhoods by total water service area for the analysis conclusion
print("\n🏆 Top 5 Pittsburgh Neighborhoods by Total Water Service Area:")
print(neighborhood_water.head())
# Explain the sub-metric logic for the final project analysis
print("\n💡 Water Infrastructure Sub-metric Explanation:")
print("Total water service area per neighborhood is used as a key sub-metric to evaluate neighborhood quality.")
print("A larger total service area indicates more extensive and reliable water infrastructure for the community.")
# Confirm data readiness for the final combined notebook
print("\n✅ Data successfully aggregated by neighborhood and ready for final combined scoring!")
